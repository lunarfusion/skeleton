{% if not paragraph.field_card_image.isEmpty() %}
  {% set image %}
    {{ content.field_card_image.0 }}
  {% endset %}
{% endif %}


{{ include ('skeleton:card', {
  image: image|default(null),
  summary: content.field_card_summary.0,
  variant: default,

  'title': [
    include('skeleton:title', {
      content: content.field_card_title,
      html_tag: 'h3',
      size: 'M',
      variant: 'card',
      }, with_context = false),
    ],

  'footer': [
    include('skeleton:link', {
      url: paragraph.field_card_url.0.url.toString(),
      label: paragraph.field_card_url.0.title,
      variant: "cta",
    }, with_context = false),
  ],

}, with_context: false) }}


