{% if paragraph.field_card_image is not empty %}
  {% set image %}
    {# {% include '@emory/utilities/media-image.twig' with {
      field: paragraph.field_card_image,
    } %} #}
    {{ content.field_card_image }}
  {% endset %}
{% endif %}

{{ include ('skeleton:card', {
  attributes: attributes,

  summary: content.field_card_summary,
  url: paragraph.field_card_url.0.url.toString(),
  variant: default,

  'title': [
    include('skeleton:title', {
      content: content.field_card_title,
      html_tag: 'h3',
      size: 'M',
      variant: 'card',
      }, with_context = false),
    ],
}) }}
