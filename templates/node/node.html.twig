{%
  set classes = [
    'article',
    'node'
  ]
%}

{% set attributes = attributes.addClass(classes|filter(v => v != '')) %}

<article{{ attributes }}>

  {{ title_prefix }}
  {% if label and not page %}
    <h2{{ title_attributes }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h2>
  {% endif %}
  {{ title_suffix }}

  {% if display_submitted %}
    <footer class="article__footer">
      <div{{ author_attributes.addClass('byline') }}>
        <span class="byline__author">
          {{ author_picture }}
          {% trans %}By {{ author_name }}
        </span>
        <span class="byline__time">
          <span class="sr-only">on</span> {{ date }}{% endtrans %}
        </span>
      </div>
    </footer>
  {% endif %}

  <div{{ content_attributes }}>
    {{ content }}
  </div>

</article>
