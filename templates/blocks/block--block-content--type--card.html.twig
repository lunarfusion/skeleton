{% set classes = [
  'block',
] %}

{% set attributes = attributes.addClass(classes|filter(v => v != '')) %}

{# render image div only if there is an image #}
{% if content.field_card_image is not empty %}
  {% set image %}
    {{ content.field_card_image }}
  {% endset %}
{% endif %}

{{ include ('skeleton:card', {
  title: content.field_card_title,
  summary: content.field_card_summary,
  url: content.field_card_link,
  variant: default,
  'title': [
    include('skeleton:title', {
      content: content.field_card_title,
      html_tag: 'h3',
      size: 'M',
      variant: 'card',
      }, with_context = false),
    ],
}) }}
