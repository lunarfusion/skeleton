{% set classes = [
  'block',
] %}

{% set attributes = attributes.addClass(classes|filter(v => v != '')) %}

<div{{ attributes }}>
  {{ title_prefix }}
  {% if label %}
    <div class="block__title">
      {{ include ('skeleton:title', {
        content: label,
        html_tag: 'h3',
        size: 'M',
        variant: 'block',
      }, with_context: false) }}
    </div>
  {% endif %}
  {{ title_suffix }}

  <div class="block__content">
    {% block content %}
      {{ content }}
    {% endblock %}
  </div>
</div>
