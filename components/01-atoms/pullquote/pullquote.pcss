/*** Pullquote Variables ***/
.pullquote {
  --skeleton-color-pullquote-icon: var(--skeleton-color-accent);
  --skeleton-color-pullquote-fg: var(--skeleton-color-fg-base);
  --skeleton-padding-pullquote: 2rem;
  --skeleton-margin-pullquote: 1rem;
}

/*** Pullquote Styles ***/
.pullquote {
  position: relative;
  padding: var(--skeleton-padding-pullquote);
  margin-inline: 1rem;
  font-size: 2rem;
  line-height: 1.3;
  color: var(--skeleton-color-pullquote-fg);
  
  &::before {
    content: "";
    position: absolute;
    width: 2rem;
    height: 2rem;
    font-size: 5rem;
    display: block;
    color: var(--skeleton-color-pullquote-icon);
    font-family: var(--skeleton-font-serif);
  }
  
  &::before {
    content: "“";
    top: 0;
    transform: translateX(calc(var(--skeleton-padding-pullquote) * -1.5));
  }
  
  /* &::after {
    content: "”";
    bottom: var(--skeleton-padding-pullquote);
    right: 0;
  } */
  
  &--small {}
  
  &--large {}
}