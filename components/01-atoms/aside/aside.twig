{%
  set classes = [
    'aside',
    variant and variant != 'default' ? 'aside--' ~ variant,
    width ? 'aside--' ~ width,
    float ? 'aside--' ~ float,
  ]
%}

{% set attributes = attributes.addClass(classes) %}

<aside{{ attributes.addClass(classes) }}>

  <span class="aside__title">{{ title }}</span>

  {% if summary.0 %}
    <span class="aside__content">{{ summary }}</span>
  {% endif %}
</aside>
