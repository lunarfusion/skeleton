.tag {
  color: var(--skeleton-color-fg-action-default);
  font-size: var(--skeleton-size-text-extra-small);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  text-decoration: none;
  display: inline-block;
  margin: 0.25rem;
  
  a:any-link {
    text-decoration: none;
  }
  
  &::before {
    content: "⏺";
  }
}