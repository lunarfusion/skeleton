.byline {
  display: flex;
  flex-flow: row wrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  margin-block: 1rem;
  inline-size: 100%;
  
  &__author {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
  
  &__time {
    justify-self: flex-end;
  }
}