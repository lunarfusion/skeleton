.page {
  display: flex;
  flex-direction: column;
}

.main {
  flex: 1;
  inline-size: 100%;
}

.layout {
  position: relative;
  inline-size: 100%;
  
  &--banner {
    margin-block-end: 2rem;
  }
  
  &--content-bottom {
    margin-block-end: 4rem;
  }
  
  &--footer {
    margin: 0;
    padding: 1rem 2rem 3rem;
    background-color: var(--skeleton-color-bg-primary);
  }
}